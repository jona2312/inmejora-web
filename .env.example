# URL del backend INMEJORA (inmejora_dashboard_aprobacion)
VITE_API_URL=https://aprobacion.inmejora.com.ar

# Google Analytics 4
VITE_GA4_ID=G-XXXXXXXXXX

# MercadoPago — SOLO la public key va en el frontend
# El ACCESS_TOKEN NUNCA debe estar aqui (quedaria expuesto en el bundle JS)
# Configurarlo como variable de servidor: MP_ACCESS_TOKEN en el backend
VITE_MERCADO_PAGO_PUBLIC_KEY=APP_USR-xxxx-xxxx-xxxx-xxxx
VITE_MERCADO_PAGO_SELLER_ID=
VITE_MERCADO_PAGO_SELLER_NAME=INMEJORA
